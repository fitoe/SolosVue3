{
  "name": "solos-vue3",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "simple-git-hooks",
    "preset:apply": "node scripts/apply-preset.mjs",
    "demo:remove": "node scripts/remove-demo.mjs"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "alova": "^3.5.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@iconify-json/carbon": "^1.2.13",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-plugin": "^66.6.8",
    "@unocss/reset": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.6",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.10",
    "vite-plugin-vue-devtools": "^8.0.4",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,mjs,cjs,json,md,css}": "eslint --fix"
  }
}
